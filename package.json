{
  "name": "pl.lukaszpodgorski.handy",
  "version": "0.1.0",
  "description": "Control Handy dictation from your Stream Deck",
  "type": "module",
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c -w --watch.onEnd=\"npx streamdeck restart pl.lukaszpodgorski.handy\""
  },
  "devDependencies": {
    "@elgato/cli": "^1.7.4",
    "@rollup/plugin-commonjs": "^28.0.1",
    "@rollup/plugin-node-resolve": "^15.3.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.1",
    "@tsconfig/node20": "^20.1.4",
    "@types/node": "^20.16.11",
    "rollup": "^4.24.0",
    "tslib": "^2.8.0",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@elgato/streamdeck": "^1.0.0"
  }
}
